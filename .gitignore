# download their own or you can use a script to fetch it).
tailwindcss
tailwindcss-*
tailwindcss.exe

# -----------------------------------------------------------------------------
# Environment & Secrets (Crucial!)
# -----------------------------------------------------------------------------
# Never commit your database URLs or API keys!
.env
.env.*
!.env.example 

